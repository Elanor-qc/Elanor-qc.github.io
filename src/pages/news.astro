---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const news = [
  { year: "2026", title: "获黄奕聪奖学金", type: "Award" },
  { year: "2025", title: "获北京大学新生奖学金", type: "Award" },
  {
    year: "2025",
    title: "进入北京大学元培学院智能科学与技术（智班）学习",
    type: "Education",
  },
];
---

<Layout title={`News | ${config.site.title}`} description="高琦程的最新动态。">
  <Header />
  <Breadcrumb />
  <Main pageTitle="News" pageDesc="近况与重要节点。">
    <ol class="border-border ms-2 border-s ps-8">
      {
        news.map(item => (
          <li class="relative pb-10 last:pb-0">
            <span class="bg-accent absolute -start-[2.55rem] top-1.5 size-3 rounded-full ring-4 ring-background" />
            <p class="text-muted-foreground text-sm font-medium">{item.year}</p>
            <h2 class="mt-1 text-lg font-semibold">{item.title}</h2>
            <p class="text-muted-foreground mt-1 text-sm">{item.type}</p>
          </li>
        ))
      }
    </ol>
  </Main>
  <Footer />
</Layout>
