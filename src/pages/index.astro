---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import config from "@/config";

const { socials } = config;

const awards = [
  { title: "黄奕聪奖学金", year: "2026", detail: "北京大学" },
  { title: "北京大学新生奖学金", year: "2025", detail: "北京大学" },
];

const news = [
  { title: "进入北京大学元培学院智能科学与技术（智班）学习", year: "2025" },
];
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1 class="my-4 text-4xl font-bold sm:my-8 sm:text-5xl">高琦程 Gao Qicheng</h1>
      <p class="max-w-2xl text-lg">北京大学元培学院 · 智能科学与技术（智班）</p>
      <p class="mt-2 max-w-2xl">Awards、News 与 Selected Publications。</p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Connect:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="awards" class="border-border border-b pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Awards</h2>
      <ul>
        {
          awards.map(award => (
            <li class="my-6">
              <h3 class="text-accent text-lg font-medium">{award.title}</h3>
              <div class="text-muted-foreground mt-2 flex items-center gap-x-2">
                <IconCalendar class="size-5" />
                <time class="text-sm">{award.year}</time>
              </div>
              <p class="mt-2">{award.detail}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section id="news" class="border-border border-b pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">News</h2>
      <ul>
        {
          news.map(item => (
            <li class="my-6">
              <h3 class="text-accent text-lg font-medium">{item.title}</h3>
              <div class="text-muted-foreground mt-2 flex items-center gap-x-2">
                <IconCalendar class="size-5" />
                <time class="text-sm">{item.year}</time>
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <section id="publications" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Selected Publications</h2>
      <p class="mt-6">暂未更新。</p>
    </section>
  </main>
  <Footer />
</Layout>
